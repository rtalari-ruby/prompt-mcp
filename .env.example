# Configure ONE provider. Azure OpenAI (chat completions) is the default.
LLM_PROVIDER=azure-openai

# Azure OpenAI (chat completions)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.5-3
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Anthropic (alternative — set LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# PROMPT_MCP_DEFAULT_MODEL=claude-sonnet-4-6
# PROMPT_MCP_HEAVY_MODEL=claude-opus-4-7

PROMPT_MCP_KB_PATH=./kb
PROMPT_MCP_CACHE_DIR=./.cache
